{
  "manifest_version": 3,
  "name": "Pattern Blocker",
  "version": "1.0.1",
  "description": "Block specific websites or URL patterns (e.g. youtube.com/shorts/*).",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "action": {
    "default_title": "Pattern Blocker (click to toggle)",
    "default_icon": { "128": "icon-128.png" }
  },
  "background": { "service_worker": "service_worker.js", "type": "module" },
  "web_accessible_resources": [{
    "resources": ["blocked.html"],
    "matches": ["<all_urls>"]
  }]
}
